{
  "uid": "streamify-flink-resources",
  "title": "Streamify - Flink CPU / Memory",
  "tags": ["streamify", "flink", "resources"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 5,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 10,
      "type": "row",
      "title": "CPU",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "timeseries",
      "title": "JVM CPU load",
      "description": "Fraction of a CPU used by each Flink JVM process.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flink_jobmanager_Status_JVM_CPU_Load",
          "legendFormat": "jobmanager"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flink_taskmanager_Status_JVM_CPU_Load",
          "legendFormat": "taskmanager {{tm_id}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Memory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "collapsed": false
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "TaskManager heap & managed memory",
      "description": "Heap memory is GC-managed Java objects. Managed memory is Flink's pre-allocated off-heap pool for operators.",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flink_taskmanager_Status_JVM_Memory_Heap_Used",
          "legendFormat": "heap used {{tm_id}}"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flink_taskmanager_Status_Flink_Memory_Managed_Used",
          "legendFormat": "managed used {{tm_id}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "JobManager heap memory",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 11 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "flink_jobmanager_Status_JVM_Memory_Heap_Used",
          "legendFormat": "heap used"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "TaskManager — total memory breakdown (stacked)",
      "description": "Heap + managed stacked together. Shows the proportional size of each memory region over time.",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "stacking": { "mode": "normal", "group": "A" }, "fillOpacity": 60, "lineWidth": 1 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "heap" },    "properties": [{ "id": "color", "value": { "fixedColor": "#5794F2", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "managed" }, "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(flink_taskmanager_Status_JVM_Memory_Heap_Used)",
          "legendFormat": "heap"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(flink_taskmanager_Status_Flink_Memory_Managed_Used)",
          "legendFormat": "managed"
        }
      ]
    }
  ]
}
